{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Weather",
  "version": "0.2.2",
  "identifier": "com.konrad.weather",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "python3 -m http.server 1420 --directory ../frontend",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Weather",
        "width": 460,
        "height": 860,
        "minWidth": 380,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Weather",
    "publisher": "Konrad Kempinski",
    "shortDescription": "A lightweight desktop weather app.",
    "longDescription": "A lightweight desktop weather app with current conditions, hourly weather, and a 7-day forecast.",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "signCommand": null,
      "timestampUrl": null,
      "tsp": false,
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      }
    }
  }
}
