{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Weather",
  "version": "0.1.0",
  "identifier": "com.konrad.weather",
  "build": {
    "frontendDist": "../",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "python3 -m http.server 1420 --directory ../",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Weather",
        "width": 460,
        "height": 860,
        "minWidth": 380,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
